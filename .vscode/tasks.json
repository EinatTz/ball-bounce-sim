{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build shared library",
            "command": "sh",
            "args": [
                "-c",
                "clang++ -shared -fPIC -o libcontroller.so *.cpp"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
